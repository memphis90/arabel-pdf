{
    "name": "arabel/pdf",
    "description": "Lightweight, zero-dependency and fast PDF generator for PHP 8.1+. Fluent & semantic API with high-level Document and low-level Pdf layers.",
    "type": "library",
    "license": "MIT",
    "keywords": ["pdf", "pdf-generator", "lightweight", "zero-dependency", "fluent", "php8", "php81", "fast-pdf", "no-dependencies", "document", "report"],
    "authors": [
        {
            "name": "Arabel",
            "homepage": "https://arabel.dev"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-zlib": "*",
        "ext-iconv": "*"
    },
    "autoload": {
        "psr-4": {
            "Arabel\\Pdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arabel\\Pdf\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
